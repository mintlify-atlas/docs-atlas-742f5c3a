  "keyFeatures": [
    "Multi-model AI chat powered by Amazon Bedrock (Claude, Nova, Llama, Mistral)",
    "Custom bot creation with RAG and knowledge bases",
    "Bot store marketplace for sharing and discovering bots",
    "AI agents with ReAct pattern and custom tool integration",
    "Multi-tenant knowledge base architecture",
    "Bot API publishing for standalone integrations",
    "Administrative controls with usage analytics",
    "Multiple authentication providers (Cognito, Google, OIDC)"
  ],
  "publicApiSurface": [
    "POST /conversations - Create and manage chat conversations",
    "GET /conversations/{id}/messages - Retrieve conversation messages",
    "POST /bots - Create custom bots with knowledge bases",
    "GET /bot-store - Browse and discover shared bots",
    "POST /bots/{id}/publish - Publish bot as standalone API",
    "POST /admin/bots/{id}/essential - Mark bots as essential",
    "GET /admin/analytics - Retrieve usage analytics",
    "BedrockChatStack - Main CDK stack for infrastructure",
    "BedrockCustomBotStack - CDK stack for bot knowledge bases",
    "ApiPublishmentStack - CDK stack for published bot APIs",
    "cdk.json context parameters - Configuration options",
    "parameter.ts - Type-safe deployment parameters"
  ]
}
